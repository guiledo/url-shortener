{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://url-shortener-knyo.onrender.com/api/:path*"
    },
    {
      "source": "/api",
      "destination": "https://url-shortener-knyo.onrender.com/api"
    },
    {
      "source": "/:code((?!api|index.html|assets|vite.svg)[^/]*)",
      "destination": "https://url-shortener-knyo.onrender.com/:code"
    }
  ]
}
